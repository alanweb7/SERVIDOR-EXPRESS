PORT=3000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=*
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=1 minute
WEBHOOK_SIGNING_SECRET=change-me
AI_INTERNAL_TOKEN=change-me-ai-token
AI_CONTEXT_WINDOW=12
AI_TRANSIENT_MAX_RETRIES=1
OPENCLAW_GATEWAY_URL=ws://openclaw:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=
OPENCLAW_SESSION_DEFAULT=agent:main:main
OPENCLAW_ENABLE_FALLBACK_CLI=false
OPENCLAW_FALLBACK_CONTAINER=openclaw-cvsy-openclaw-1
OPENCLAW_CONNECT_TIMEOUT_MS=15000
OPENCLAW_DEBUG=false
DATA_PROVIDER=inmemory
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
